          "name": "change-password",
          "item": [
            {
              "name": "Change password",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status code is 200\", function () {\r",
                      "    pm.response.to.have.status(200);\r",
                      "});\r",
                      "pm.test(\"Body matches string\", function () {\r",
                      "    pm.expect(pm.response.text()).to.include(\"true\");\r",
                      "});\r",
                      "pm.test(\"Response time is less than 5000ms\", function () {\r",
                      "    pm.expect(pm.response.responseTime).to.be.below(5000);\r",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                },
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "// Function to generate secure password\r",
                      "function generatePassword(length) {\r",
                      "    const upper = \"ABCDEFGHIJKLMNOPQRSTUVWXYZ\";\r",
                      "    const lower = \"abcdefghijklmnopqrstuvwxyz\";\r",
                      "    const numbers = \"0123456789\";\r",
                      "    const symbols = \"!@#$%^&*\";\r",
                      "    const allChars = upper + lower + numbers + symbols;\r",
                      "\r",
                      "    let password = \"\";\r",
                      "\r",
                      "    password += upper[Math.floor(Math.random() * upper.length)];\r",
                      "    password += lower[Math.floor(Math.random() * lower.length)];\r",
                      "    password += numbers[Math.floor(Math.random() * numbers.length)];\r",
                      "    password += symbols[Math.floor(Math.random() * symbols.length)];\r",
                      "\r",
                      "    for (let i = password.length; i < length; i++) {\r",
                      "        password += allChars[Math.floor(Math.random() * allChars.length)];\r",
                      "    }\r",
                      "\r",
                      "    password = password.split('').sort(() => 0.5 - Math.random()).join('');\r",
                      "\r",
                      "    return password;\r",
                      "}\r",
                      "\r",
                      "// Get old password\r",
                      "const oldPassword = pm.collectionVariables.get(\"password\");\r",
                      "\r",
                      "// Generate new password\r",
                      "const newPassword = generatePassword(12);\r",
                      "\r",
                      "// Save new password temporarily\r",
                      "pm.collectionVariables.set(\"new_password\", newPassword);"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
